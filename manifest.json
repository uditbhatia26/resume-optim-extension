{
    "manifest_version": 3,
    "name": "ResumeSculpt - AI Resume Optimizer",
    "version": "1.0.0",
    "description": "Optimize your resume for any job with AI-powered matching and tailoring",
    "permissions": [
        "storage",
        "activeTab",
        "scripting"
    ],
    "host_permissions": [
        "http://localhost:8000/*",
        "https://your-domain.com/*"
    ],
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "ResumeSculpt"
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    }
}