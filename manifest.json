{
    "manifest_version": 3,
    "name": "ResumeSculpt - AI Resume Optimizer",
    "version": "1.0.0",
    "description": "Optimize your resume for any job with AI-powered matching and tailoring",
    "permissions": [
        "storage",
        "activeTab",
        "scripting",
        "tabs",
        "identity"
    ],
    "oauth2": {
        "client_id": "551941315184-9mf9khph2hkv1v7k89m0ngidh83nh2v7.apps.googleusercontent.com",
        "scopes": ["openid", "email", "profile"]
    },

    "content_scripts": [
        {
            "matches": ["<all_urls>"],
            "js": ["content/content.js"],
            "run_at": "document_idle"
        }
    ],
    "host_permissions": [
        "http://localhost:8000/*",
        "https://your-domain.com/*",
        "https://accounts.google.com/*",
        "https://www.googleapis.com/*"
    ],
    "background": {
        "service_worker": "background.js"
    },
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    },
    "action": {
        "default_popup": "popup/popup.html",
        "default_title": "ResumeSculpt",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "content_security_policy": {
        "extension_pages": "script-src 'self'; object-src 'self'"
    }
}