{
    "manifest_version": 3,
    "name": "ResumeSculpt",
    "version": "1.0",
    "description": "ResumeSculpt helps you personalize your resume using AI based on the job description.",
    "action": {
        "default_popup": "popup/popup.html",
        "default_icon": {
            "16": "icons/icon16.png",
            "48": "icons/icon48.png",
            "128": "icons/icon128.png"
        }
    },
    "permissions": [
        "activeTab",
        "https://api_for_product.com/"
    ],
    "icons": {
        "16": "icons/icon16.png",
        "48": "icons/icon48.png",
        "128": "icons/icon128.png"
    }
}